{
  "name": "user-manager",
  "version": "1.0.0",
  "description": "Managing user login/signup, testing backend.",
  "license": "ISC",
  "author": "Quib Inc.",
  "type": "module",
  "scripts": {
    "host": "npx nodemon --exec tsx ./ts-api/hoster.ts",
    "build-pages": "esbuild ./tsx-pages/*.tsx --bundle --minify --sourcemap --format=esm --outdir=./js-pages",
    "build-app": "esbuild ./ts-api/app.ts --bundle --minify --sourcemap --format=esm --platform=node --outdir=./api",
    "build-exporter": "esbuild ./ts-api/exporter.ts --minify --sourcemap --format=esm --platform=node --packages=external --outdir=./api",
    "build": "npm run build-pages && npm run build-app && npm run build-exporter",
    "sql": "psql $(dotenv -p POSTGRES_URL)"
  },
  "main": "api/exporter.js",
  "dependencies": {
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "http": "^0.0.1-security",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react-dom": "^19.2.3",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.4"
  }
}
